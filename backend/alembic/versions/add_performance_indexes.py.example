"""添加性能索引

Revision ID: add_performance_indexes
Revises:
Create Date: 2026-05-16

该迁移通过增加索引提升查询性能。
"""
from alembic import op


# 迁移标识，由 Alembic 使用。
revision = 'add_performance_indexes'
down_revision = None  # Update this to the latest migration
branch_labels = None
depends_on = None


def upgrade():
    """添加性能索引。"""

    # 用户表索引
    op.create_index(
        'idx_users_org_status',
        'users',
        ['org_id', 'status', 'is_deleted'],
        postgresql_where='is_deleted = false'
    )
    op.create_index(
        'idx_users_username',
        'users',
        ['username'],
        unique=True,
        postgresql_where='is_deleted = false'
    )
    op.create_index(
        'idx_users_phone',
        'users',
        ['phone'],
        unique=True,
        postgresql_where='is_deleted = false'
    )

    # 上传文件表索引
    op.create_index(
        'idx_upload_files_org_created',
        'upload_files',
        ['org_id', 'created_at', 'is_deleted']
    )
    op.create_index(
        'idx_upload_files_status',
        'upload_files',
        ['status', 'is_deleted']
    )
    op.create_index(
        'idx_upload_files_platform',
        'upload_files',
        ['platform_id', 'is_deleted']
    )

    # 处理任务表索引
    op.create_index(
        'idx_processing_tasks_file_status',
        'processing_tasks',
        ['file_id', 'status']
    )
    op.create_index(
        'idx_processing_tasks_created',
        'processing_tasks',
        ['created_at']
    )

    # 汇总表索引
    op.create_index(
        'idx_summaries_org_date',
        'summaries',
        ['org_id', 'date', 'is_deleted']
    )
    op.create_index(
        'idx_summaries_platform_date',
        'summaries',
        ['platform_id', 'date', 'is_deleted']
    )
    op.create_index(
        'idx_summaries_shop_date',
        'summaries',
        ['shop_id', 'date', 'is_deleted']
    )

    # 审计日志表索引
    op.create_index(
        'idx_audit_logs_user_created',
        'audit_logs',
        ['user_id', 'created_at']
    )
    op.create_index(
        'idx_audit_logs_org_created',
        'audit_logs',
        ['org_id', 'created_at']
    )
    op.create_index(
        'idx_audit_logs_module_action',
        'audit_logs',
        ['module', 'action', 'created_at']
    )


def downgrade():
    """移除性能索引。"""

    # 按逆序删除所有索引
    op.drop_index('idx_audit_logs_module_action')
    op.drop_index('idx_audit_logs_org_created')
    op.drop_index('idx_audit_logs_user_created')

    op.drop_index('idx_summaries_shop_date')
    op.drop_index('idx_summaries_platform_date')
    op.drop_index('idx_summaries_org_date')

    op.drop_index('idx_processing_tasks_created')
    op.drop_index('idx_processing_tasks_file_status')

    op.drop_index('idx_upload_files_platform')
    op.drop_index('idx_upload_files_status')
    op.drop_index('idx_upload_files_org_created')

    op.drop_index('idx_users_phone')
    op.drop_index('idx_users_username')
    op.drop_index('idx_users_org_status')
