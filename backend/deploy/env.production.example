# Core runtime
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/finengine
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
# App cache, captcha, and replay guard.
REDIS_URL=redis://127.0.0.1:6379/0
# Celery broker and result backend. Keep it separate from REDIS_URL.
CELERY_REDIS_URL=redis://127.0.0.1:6379/1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_HOURS=24
ALGORITHM=HS256
SUPERADMIN_INIT_PASSWORD=change-me

# CORS
CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=15
LOG_ROTATION_TIME=00:00

# Upload
MAX_UPLOAD_SIZE_MB=1024

# API encryption
API_CRYPTO_ENABLED=true
API_CRYPTO_REPLAY_WINDOW_SECONDS=300
# Required when API_CRYPTO_ENABLED=true. Generate a key pair and put the matching
# public key into frontend VITE_API_CRYPTO_PUBLIC_KEY before building.
API_CRYPTO_PRIVATE_KEY=

# OSS / STS
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_OSS_REGION=cn-hangzhou
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ENDPOINT=
INTERNAL_DOWNLOAD=false
ALIYUN_OSS_INTERNAL_ENDPOINT=
ALIYUN_STS_ROLE_ARN=
ALIYUN_STS_EXPIRE_SECONDS=3600
ALIYUN_STS_POLICY=

# API process
APP_HOST=127.0.0.1
APP_PORT=8000
APP_WORKERS=2
APP_FORWARDED_ALLOW_IPS=*

# Celery worker
CELERY_LOG_LEVEL=INFO
CELERY_POOL=solo
CELERY_HOSTNAME=finengine@%h
CELERY_QUEUES=
CELERY_CONCURRENCY=

# Flower Celery monitor. Keep it bound to localhost and protect it behind nginx
# or SSH tunnel if you expose it.
FLOWER_HOST=127.0.0.1
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=
