# FinEngine backend environment example

# Application
# SECURITY WARNING: Generate a strong random key for production!
# Run: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24
# SECURITY WARNING: Change this password immediately after first deployment!
SUPERADMIN_INIT_PASSWORD=admin123
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","http://localhost:5175","http://127.0.0.1:5175","http://localhost:3000","http://127.0.0.1:3000"]

# Database, cache, and queue
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finengine
# App cache, captcha, and replay guard.
REDIS_URL=redis://localhost:6379/0
# Celery broker and result backend. Keep it separate from REDIS_URL.
CELERY_REDIS_URL=redis://localhost:6379/1

# Upload limits
MAX_UPLOAD_SIZE_MB=1024

# API encryption. Generate a key pair and put the matching public key into
# frontend VITE_API_CRYPTO_PUBLIC_KEY before building.
API_CRYPTO_ENABLED=false
API_CRYPTO_REPLAY_WINDOW_SECONDS=300
API_CRYPTO_PRIVATE_KEY=

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=15

# Sentry error tracking (optional but recommended for production)
# Sign up at https://sentry.io and create a project to get your DSN
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Alibaba Cloud account credentials used by the backend worker and STS API.
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# Alibaba Cloud OSS bucket used for uploads and worker-side file processing.
ALIYUN_OSS_REGION=oss-cn-guangzhou
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ENDPOINT=https://oss-cn-guangzhou.aliyuncs.com

# Optional: STS role for /api/v1/oss/sts temporary browser credentials.
# Browser uploads use temporary credentials scoped to a single upload batch.
ALIYUN_STS_ROLE_ARN=
ALIYUN_STS_EXPIRE_SECONDS=3600
ALIYUN_STS_POLICY=
